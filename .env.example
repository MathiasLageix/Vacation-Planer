# Copie ce fichier vers .env et remplis tes vraies clés.
# Ne JAMAIS commiter .env (il est dans .gitignore).

# --- Anthropic (cerveau de l'agent) ---
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Duffel (vols + hôtels) ---
# https://duffel.com/dashboard -> Settings -> API keys
DUFFEL_API_KEY=

# --- Base de données ---
# SQLite local (dev)
DATABASE_URL=sqlite:///travel_agent.db
# Postgres Railway (prod) : copier l'URL depuis Railway → Variables → DATABASE_URL
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Configuration générale ---
CLAUDE_MODEL=claude-sonnet-4-6

# --- Variables Railway (à ne pas mettre en local) ---
# Renseignées automatiquement par Railway entre les services.
# FRONTEND_URL=https://ton-frontend.up.railway.app   # → backend : CORS autorisé
# API_URL=https://ton-backend.up.railway.app          # → frontend : proxy Next.js
