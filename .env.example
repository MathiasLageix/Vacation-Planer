# Copie ce fichier vers .env et remplis tes vraies clés.
# Ne JAMAIS commiter .env (il est dans .gitignore).

# --- Anthropic (cerveau de l'agent) ---
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Amadeus Self-Service (vols, hôtels, autos) ---
# https://developers.amadeus.com  -> crée une app pour obtenir la clé + le secret
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# "test" pour l'environnement de test gratuit, "production" plus tard
AMADEUS_ENV=test

# --- Duffel (vols, alternative optionnelle) ---
# https://duffel.com
DUFFEL_API_KEY=

# --- Configuration générale ---
# Modèle Claude utilisé par l'agent
CLAUDE_MODEL=claude-sonnet-4-6
# Chemin de la base SQLite locale
DATABASE_URL=sqlite:///travel_agent.db
